function AnimatedNumber({ from, to, duration = 1500 }) {
  const [val, setVal] = useState(from);
  useEffect(() => {
    let start = null;
    const step = (ts) => {
      if (!start) start = ts;
      const progress = Math.min((ts - start) / duration, 1);
